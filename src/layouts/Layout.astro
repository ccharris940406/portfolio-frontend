---
import NavBar from "../components/NavBar.astro";
import ChatBubble from "../components/ChatBubble.tsx";
import "../styles/global.css";
import SEO from "../components/SEO.astro";
---

<html lang="es">
    <head>
        <SEO
            title="Carlos César Harris Castillo — Full Stack Developer"
            description="Desarrollador Full Stack especializado en Odoo, React Native y Docker. Experiencia en desarrollo web, mobile y ERP."
            author="Carlos César Harris Castillo"
            image="https://ccharris.vercel.app/banner.jpg"
            url="https://ccharris.vercel.app"
            jsonLd={{
                "@context": "https://schema.org",
                "@type": "Person",
                "name": "Carlos César Harris Castillo",
                "jobTitle": "Full Stack Developer",
                "description": "Desarrollador Full Stack especializado en Odoo, React Native y Docker",
                "url": "https://ccharris.vercel.app",
            }}
        />
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.png" />
        <link rel="icon" href="/favicon.ico" type="image/x-icon" />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
            integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
            crossorigin="anonymous"
            referrerpolicy="no-referrer"
        />
        <meta name="generator" content={Astro.generator} />
    </head>
    <body>
        <header>
            <NavBar />
        </header>
        <slot />
        <ChatBubble client:load />
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
