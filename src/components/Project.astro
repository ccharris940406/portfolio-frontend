---
interface Props {
    title: string;
    description: string;
    imageURL: string;
    techs: string[];
    repository?: string;
}

const {
    title,
    description,
    imageURL,
    techs,
    repository = "#",
} = Astro.props as Props;
---

<style>
    .flip-card {
        perspective: 1000px;
    }

    .flip-inner {
        transition: transform 0.6s;
        transform-style: preserve-3d;
    }

    .flip-card:hover .flip-inner,
    .flip-card:focus-within .flip-inner,
    .flip-card.flipped .flip-inner {
        transform: rotateY(180deg);
    }

    .flip-front,
    .flip-back {
        backface-visibility: hidden;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 1rem;
        overflow: hidden;
    }

    .flip-back {
        transform: rotateY(180deg);
    }
</style>

<div class="flip-card w-full max-w-xs h-72 sm:h-40 md:h-60 relative">
    <div class="flip-inner w-full h-full relative">
        <!-- Front -->
        <div
            class="flip-front bg-white shadow-md flex flex-col justify-end items-center"
        >
            <div
                class="flex bg-[var(--color-cards)] z-10 w-full h-25 relative self-end"
            >
                <h3 class="text-lg font-semibold mt-2 text-[var(--color-text)]">
                    {title}
                </h3>
            </div>
            <img
                src={imageURL}
                alt={title}
                class="absolute top-0 left-0 w-auto h-auto"
            />
        </div>

        <!-- Back -->
        <div
            class="flip-back bg-gray-900 text-white shadow-md p-4 flex flex-col justify-between"
        >
            <div>
                <h3 class="text-xl font-semibold">{title}</h3>
                <p class="text-sm mt-2">{description}</p>
            </div>
            <div class="mt-4">
                <p class="text-xs text-gray-400 mb-1">Tech:</p>
                <ul class="flex flex-wrap gap-1 text-xs">
                    {
                        techs.map((tech) => (
                            <li class="bg-gray-700 px-2 py-0.5 rounded">
                                {tech}
                            </li>
                        ))
                    }
                </ul>
                <a
                    href={repository}
                    target="_blank"
                    class="block mt-3 text-blue-400 hover:underline text-sm"
                >
                    Ver proyecto →
                </a>
            </div>
        </div>
    </div>
</div>
