---
interface ProjectCardProps {
    title: string;
    description: string;
    imageUrl: string;
    techs: string[];
    repository: string;
    orientation: "landscape" | "portrait" | "square";
}

const { title, description, imageUrl, techs, repository } =
    Astro.props as ProjectCardProps;
---

<article
    class="project-card rounded-xl overflow-hidden cursor-pointer transition-all duration-300 hover:scale-[1.03] hover:shadow-xl flex flex-col"
    style="background-color: var(--color-cards);"
    data-title={title}
    data-description={description}
    data-techs={JSON.stringify(techs)}
    data-repository={repository}
    data-image={imageUrl}
    role="button"
    tabindex="0"
>
    <div class="relative overflow-hidden">
        <img
            src={imageUrl}
            alt={title}
            class="w-full h-36 object-cover transition-transform duration-300 group-hover:scale-105"
        />
        <div
            class="absolute inset-0 bg-linear-to-t from-black/60 to-transparent opacity-0 hover:opacity-100 transition-opacity duration-300 flex items-end p-3"
        >
            <span class="text-white text-xs font-medium">Ver detalles →</span>
        </div>
    </div>
    <div class="p-3">
        <h3
            class="font-semibold text-sm leading-tight line-clamp-2"
            style="color: var(--color-secondary);"
        >
            {title}
        </h3>
    </div>
</article>
